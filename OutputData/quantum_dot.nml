	Nx=10,
	Ny=10,
	dx=.39,
	norbs=6,
	nstate_1 = 20,
	nstate_2 = 2,
	k_electrons = 2,
	dt = 1.0,
	t_max = 1.0/

&physical_parameters
	th=0.04,
	tl=0.875,
	td=0.04,
	dso=0.01,
	drso=0.02,
	dE=0.047,
	g=3.0,
	eps_r = 100.0/

