	omega = 3e-4,
	Bx=0.0,
	By=0.0,
	Bz=0.0,
	domega_ac = 50e-3,
	omega_ac_max = 50e-3,
	f_ac = 1e6,
	Vb = 50.0e-3,
	V0 = 40.0e-3,
	d_image = 2.0,
	initialize_image= .FALSE.,
	shift_packet = 2.0,
	sigma_packet = 5.0/

